@model IEnumerable<ASP_PM.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<h2>Projects</h2>
@if (User.IsInRole("Director") || User.IsInRole("ProjectManager")){
    <p>
        <a asp-controller="ProjectWizard" asp-action="Wizard" class="btn btn-success">New Project</a>
    </p>
}
<form method="get" asp-action="Index" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label>Start date from</label>
            <input type="date" name="startDateFrom" class="form-control" />
        </div>
        <div class="col-md-2">
            <label>Start date to</label>
            <input type="date" name="startDateTo" class="form-control" />
        </div>
        <div class="col-md-2">
            <label>Priority</label>
            <input type="number" name="priority" class="form-control" />
        </div>
        <div class="col-md-2">
            <label>Sort by</label>
            <select name="sortBy" class="form-select">
                <option value="name">Name</option>
                <option value="startdate">Start Date</option>
                <option value="priority">Priority</option>
            </select>
        </div>
        <div class="col-md-2">
            <label>Ascending</label>
            <select name="ascending" class="form-select">
                <option value="true">Asc</option>
                <option value="false">Desc</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col">
            <a asp-action="Index" class="btn btn-secondary">Reset</a>
        </div>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Client</th>
            <th>Executor Company</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Priority</th>
            <th>Manager</th>
            <th>Tasks</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var canEditDelete = User.IsInRole("Director") || (User.IsInRole("ProjectManager") && item.ProjectManagerId == ViewBag.CurrentEmployeeId);
            var canViewDetails = !canEditDelete && User.IsInRole("Employee") && item.Executors.Any(e => e.Id == ViewBag.CurrentEmployeeId);
            <tr>
                <td>@item.Name</td>
                <td>@item.ClientCompany</td>
                <td>@item.ExecutorCompany</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.Priority</td>
                <td>@(item.ProjectManager?.FullName ?? "-")</td>
                <td>@(item.Tasks?.Count ?? 0)</td>
                <td>
                    @if (canEditDelete)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this project?')">Delete</button>
                        </form>
                    }
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                  </td>
              </tr>
        }
    </tbody>
</table>
