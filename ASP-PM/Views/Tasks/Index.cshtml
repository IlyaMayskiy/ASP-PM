@model IEnumerable<ASP_PM.Models.TaskItem>
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@inject IEmployeeService EmployeeService

@{
    ViewData["Title"] = "Tasks";
}

<h2>Tasks</h2>

<form method="get" asp-action="Index">
    <div class="row">
        <div class="col-md-3">
            <label>Project</label>
            <select name="projectId" asp-items="ViewBag.Projects" class="form-control">
                <option value="">-- All --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Status</label>
            <select name="status" asp-items="ViewBag.Statuses" class="form-control">
                <option value="">-- All --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Sort by</label>
            <select name="sortBy" class="form-control">
                <option value="name">Name</option>
                <option value="priority">Priority</option>
                <option value="status">Status</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Ascending</label>
            <select name="ascending" class="form-control">
                <option value="true">Asc</option>
                <option value="false">Desc</option>
            </select>
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-2">Apply</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Reset</a>
</form>

@if (User.IsInRole("Director") || User.IsInRole("ProjectManager"))
{
    <p>
        <a asp-action="Create" class="btn btn-success mt-3">Create New Task</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Project</th>
            <th>Author</th>
            <th>Executor</th>
            <th>Status</th>
            <th>Priority</th>
            @if (User.IsInRole("Director") || User.IsInRole("ProjectManager"))
            {
                <th>Actions</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var canChangeStatus = false;
            var currentUser = await UserManager.GetUserAsync(User);
            if (currentUser != null)
            {
                var currentEmployee = await EmployeeService.GetByAppUserIdAsync(currentUser.Id);
                if (User.IsInRole("Director"))
                    canChangeStatus = true;
                else if (User.IsInRole("ProjectManager"))
                {
                    canChangeStatus = true;
                }
                else if (User.IsInRole("Employee") && currentEmployee != null && item.ExecutorId == currentEmployee.Id)
                {
                    canChangeStatus = true;
                }
            }

            <tr>
                <td>@item.Name</td>
                <td>@item.Project?.Name</td>
                <td>@item.Author?.FullName</td>
                <td>@item.Executor?.FullName</td>
                <td>
                    @if (canChangeStatus)
                    {
                        <select class="task-status" data-task-id="@item.Id" data-current-status="@item.Status.ToString()">
                            <option value="ToDo" selected="@(item.Status == TaskState.ToDo)">ToDo</option>
                            <option value="InProgress" selected="@(item.Status == TaskState.InProgress)">InProgress</option>
                            <option value="Done" selected="@(item.Status == TaskState.Done)">Done</option>
                        </select>
                    }
                    else
                    {
                        @item.Status.ToString()
                    }
                </td>
                <td>@item.Priority</td>
                @if (User.IsInRole("Director") || User.IsInRole("ProjectManager"))
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" onclick="return confirm('Delete this task?')">Delete</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.task-status').change(function() {
                var select = $(this);
                var taskId = select.data('task-id');
                var newStatus = select.val();
                $.ajax({
                    url: '@Url.Action("UpdateTaskStatus", "Projects")',
                    type: 'POST',
                    data: { taskId: taskId, status: newStatus },
                });
            });
        });
    </script>
}